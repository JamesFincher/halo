{
  "description": "Halo true loop — Stop hook re-injects NEXT_PROMPT as the next user turn when autonomous mode is active",
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${GROK_PLUGIN_ROOT:-$CLAUDE_PLUGIN_ROOT}/hooks/halo-stop-loop.sh\"",
            "timeout": 30
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${GROK_PLUGIN_ROOT:-$CLAUDE_PLUGIN_ROOT}/hooks/halo-session-start.sh\"",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
