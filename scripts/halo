#!/usr/bin/env bash
# Halo CLI — minimal public lifecycle surface.
set -euo pipefail

HALO_SYSTEM="$(cd "$(dirname "$0")/.." && pwd)"
PY="${PYTHON:-python3}"
export PYTHONPATH="${HALO_SYSTEM}/python${PYTHONPATH:+:$PYTHONPATH}"

die() { echo "error: $*" >&2; exit 1; }
repo_arg() {
  local r="${1:-.}"
  cd "$r" 2>/dev/null || die "repo not found: $r"
  pwd
}

cmd="${1:-help}"
shift || true

case "$cmd" in
  help|-h|--help)
    cat <<'EOF'
halo — autonomous product lifecycle

  init [path]          Bootstrap a new product
  status [path]        Show phase, readiness, story, demo
  specs [path]         Write .halo/spec/* from intake
  lock [path]          Lock specs → readiness
  unlock [path]        Unlock specs for revision
  ready [path]         Run readiness gate
  scaffold [path]      Scaffold app + milestones + Demo 0
  build [path]         Show build-cycle instructions
  go [path]            Start autonomous mode
  stop [path]          Pause autonomous / set PAUSED
  resume [path]        Resume active
  continue [path]      Refresh NEXT_PROMPT
  handoff [path]       Write context pack for another agent
  doctor [path]        Validate system + product
  help                 Show this help

EOF
    ;;

  init)
    path="$(repo_arg "${1:-.}")"
    mkdir -p "$path"
    "$PY" "$HALO_SYSTEM/python/halo_state.py" init --repo "$path" --force 2>/dev/null \
      || "$PY" "$HALO_SYSTEM/python/halo_state.py" init --repo "$path"
    for f in AGENTS.md HALO.md CLAUDE.md; do
      if [[ ! -f "$path/$f" && -f "$HALO_SYSTEM/templates/project/$f" ]]; then
        cp "$HALO_SYSTEM/templates/project/$f" "$path/$f"
      fi
    done
    echo "init ok → $path"
    ;;

  status)
    path="$(repo_arg "${1:-.}")"
    if [[ ! -f "$path/.halo/state.json" ]]; then
      die "not a Halo product — run halo init"
    fi
    "$PY" - <<PY
import json
import os
from datetime import datetime, timezone
from pathlib import Path
from halo_features import summary as feature_summary
p = Path('$path')
with open(p / '.halo' / 'state.json', encoding='utf-8') as f:
    s = json.load(f)
print(f"product: {s.get('product_name')}")
print(f"status:  {s.get('status')}")
print(f"phase:   {s.get('phase')}")
print(f"spec:    {s.get('spec_status')}")
print(f"ready:   {s.get('readiness_verdict')}")
print(f"story:   {s.get('current_story')}")
print(f"demo:    {s.get('last_demo_url')}")
fs = feature_summary(p, compound=False)
print(f"features: {fs.get('passed')}/{fs.get('total')} remaining={fs.get('remaining')} all_pass={fs.get('all_pass')}")
nxt = fs.get('next') or {}
nid = nxt.get('id') if isinstance(nxt, dict) else None
print(f"next: {nid or '-'}")
print(f"scores_count: {fs.get('scores_count')}")
print(f"trajectories_count: {fs.get('trajectories_count')}")
print(f"scores_trajectories_match: {'true' if fs.get('scores_trajectories_match') else 'false'}")
print(f"latest_score_id: {fs.get('latest_score_id') or '-'}")
print(f"latest_trajectory_id: {fs.get('latest_trajectory_id') or '-'}")
# budget / watchdog health
try:
    from halo_budget import check as budget_check
    bv = budget_check(p)
    v = str(bv.get('verdict') or '?')
    print(f"budget:   {v} reason={bv.get('reason')}")
except Exception as e:
    print(f"budget:   (error: {e})")
try:
    import time as _time
    wpid = None
    walive = False
    wpid_p = p / '.halo' / 'logs' / 'watchdog.pid'
    whb_p = p / '.halo' / 'logs' / 'watchdog-heartbeat.json'
    if wpid_p.exists():
        wpid = int(wpid_p.read_text().strip() or '0') or None
        if wpid:
            try:
                os.kill(wpid, 0)
                walive = True
            except OSError:
                walive = False
    age = None
    if whb_p.exists():
        hb = json.loads(whb_p.read_text())
        at = hb.get('at')
        if at:
            ts = str(at).replace('Z', '+00:00')
            then = datetime.fromisoformat(ts)
            if then.tzinfo is None:
                then = then.replace(tzinfo=timezone.utc)
            age = max(0, int((datetime.now(timezone.utc) - then).total_seconds()))
    print(f"watchdog: pid={wpid} alive={walive} heartbeat_age={age}")
except Exception as e:
    print(f"watchdog: (error: {e})")
PY
    if [[ -f "$path/.halo/baton.md" ]]; then
      echo "--- baton ---"
      cat "$path/.halo/baton.md"
    fi
    ;;

  specs)
    path="$(repo_arg "${1:-.}")"
    "$PY" "$HALO_SYSTEM/python/halo_spec_write.py" --repo "$path"
    ;;

  lock)
    path="$(repo_arg "${1:-.}")"
    "$PY" "$HALO_SYSTEM/python/halo_state.py" lock-specs --repo "$path"
    ;;

  unlock)
    path="$(repo_arg "${1:-.}")"
    "$PY" "$HALO_SYSTEM/python/halo_state.py" set --repo "$path" --phase spec_review --spec-status drafting --status ACTIVE --force 2>/dev/null \
      || "$PY" "$HALO_SYSTEM/python/halo_state.py" set --repo "$path" --phase spec_review --spec-status drafting --status ACTIVE
    echo "unlocked → spec_review"
    ;;

  ready)
    path="$(repo_arg "${1:-.}")"
    "$PY" "$HALO_SYSTEM/python/halo_readiness.py" --repo "$path" --write
    ;;

  scaffold)
    path="$(repo_arg "${1:-.}")"
    "$PY" "$HALO_SYSTEM/python/halo_scaffold.py" \
      --repo "$path" --halo-system "$HALO_SYSTEM" --profile auto --demo0 local
    ;;

  build)
    path="$(repo_arg "${1:-.}")"
    echo "Halo build cycle:"
    echo "1. Read $path/.halo/baton.md + state.json"
    echo "2. Pick next pending story from .halo/spec/STORIES.md or milestones"
    echo "3. RED → impl → GREEN → verify → deploy → probe → only then share URL"
    echo "4. Write evidence, update baton, then run: halo continue"
    if [[ -f "$path/.halo/milestones/index.json" ]]; then
      "$PY" -c "import json; d=json.load(open('$path/.halo/milestones/index.json')); ms=[m for m in d.get('milestones',[]) if m.get('status')=='pending']; print(ms[0]['prompt'] if ms else '(none pending)')"
    fi
    ;;

  go)
    path="$(repo_arg "${1:-.}")"
    export HALO_SYSTEM
    "$PY" "$HALO_SYSTEM/python/halo_link_skills.py" --halo-system "$HALO_SYSTEM" --repo "$path" >/dev/null 2>&1 || true
    "$PY" "$HALO_SYSTEM/python/halo_go.py" --repo "$path" --enable --max-cycles 5
    ;;

  stop)
    path="$(repo_arg "${1:-.}")"
    "$PY" "$HALO_SYSTEM/python/halo_state.py" set --repo "$path" --status PAUSED
    "$PY" "$HALO_SYSTEM/python/halo_go.py" --repo "$path" --disable 2>/dev/null || true
    echo "PAUSED"
    ;;

  resume)
    path="$(repo_arg "${1:-.}")"
    "$PY" "$HALO_SYSTEM/python/halo_state.py" set --repo "$path" --status ACTIVE
    echo "ACTIVE"
    ;;

  continue)
    path="$(repo_arg "${1:-.}")"
    export HALO_SYSTEM PYTHONPATH="${HALO_SYSTEM}/python${PYTHONPATH:+:$PYTHONPATH}"
    "$PY" "$HALO_SYSTEM/python/halo_next_prompt.py" --repo "$path" --halo-system "$HALO_SYSTEM" --write
    echo "wrote $path/.halo/NEXT_PROMPT.md"
    ;;

  handoff)
    path="$(repo_arg "${1:-.}")"
    export PYTHONPATH="${HALO_SYSTEM}/python${PYTHONPATH:+:$PYTHONPATH}"
    "$PY" - <<PY
import json
from datetime import datetime, timezone
from pathlib import Path
from halo_features import summary as feature_summary
p = Path('$path')
state = {}
try:
    state = json.loads((p / '.halo' / 'state.json').read_text(encoding='utf-8'))
except Exception:
    pass
fs = feature_summary(p, compound=False)
phase = state.get('phase') or '?'
nxt = fs.get('next') or {}
nid = nxt.get('id') if isinstance(nxt, dict) else None
next_feature = nid if nid else 'all_pass'
sc = int(fs.get('scores_count') or 0)
tc = int(fs.get('trajectories_count') or 0)
match = bool(fs.get('scores_trajectories_match'))
lsid = fs.get('latest_score_id') or '-'
ltid = fs.get('latest_trajectory_id') or '-'
baton = ''
if (p / '.halo' / 'baton.md').exists():
    baton = (p / '.halo' / 'baton.md').read_text(encoding='utf-8')
spec_index = ''
if (p / '.halo' / 'spec').is_dir():
    spec_index = '\n'.join(sorted(p.name for p in (p / '.halo' / 'spec').iterdir() if p.is_file()))
out = f"""# Halo handoff
Generated: {datetime.now(timezone.utc).isoformat().replace('+00:00', 'Z')}

## Snapshot
- phase={phase}
- next_feature={next_feature}
- scores_count: {sc}
- trajectories_count: {tc}
- scores_trajectories_match: {'true' if match else 'false'}
- latest_score_id: {lsid}
- latest_trajectory_id: {ltid}

## Continue
1. Read AGENTS.md and .halo/baton.md
2. Read docs/WORKFLOWS.md in Halo system if phase unclear
3. Run: halo status

## State
```json
{json.dumps(state, indent=2)}
```

## Baton
{baton}

## Spec index
{spec_index}
"""
(p / '.halo' / 'handoff.md').write_text(out, encoding='utf-8')
PY
    echo "handoff → $path/.halo/handoff.md"
    ;;

  doctor)
    path="$(repo_arg "${1:-.}")"
    export PYTHONPATH="${HALO_SYSTEM}/python${PYTHONPATH:+:$PYTHONPATH}"
    "$PY" "$HALO_SYSTEM/python/halo_doctor.py" --halo-system "$HALO_SYSTEM" --repo "$path"
    ;;

  *)
    die "unknown command: $cmd (try: halo help)"
    ;;
esac
